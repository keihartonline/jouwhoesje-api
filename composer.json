{
    "name": "keihartonline/jouwhoesje-api",
    "type": "library",
    "license": "proprietary",
    "description": "API services t.b.v. communicatie website en backend.",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0",
        "illuminate/http": "^10.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5.3"
    },
    "autoload": {
        "psr-4": {
            "KeihartOnline\\JouwHoesjeApi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KeihartOnline\\JouwHoesjeApi\\JouwHoesjeApiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

{
    "name": "keihartonline/jouwhoesje-api",
    "type": "library",
    "license": "proprietary",
    "description": "API services t.b.v. communicatie website en backend.",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/http": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "KeihartOnline\\JouwHoesjeApi\\": "src/"
        }
    },
    "extra": {
